<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- API 26–32: broad external storage read -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- API 33+: granular media permission -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Background playback -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Required to launch ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".WavdropApp"
        android:allowBackup="false"
        android:icon="@mipmap/wavdrop_icon_midnight_violet"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/wavdrop_icon_midnight_violet_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Wavdrop">

        <!--
            MainActivity: no LAUNCHER intent filter here.
            All launcher entry points are provided by the activity-alias entries below
            so that the launcher icon and label can be switched without killing the app.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="audio/*" />
                <data android:mimeType="audio/mpeg" />
                <data android:mimeType="audio/mp4" />
                <data android:mimeType="audio/aac" />
                <data android:mimeType="audio/flac" />
                <data android:mimeType="audio/ogg" />
                <data android:mimeType="audio/wav" />
                <data android:mimeType="audio/x-wav" />
                <data android:mimeType="audio/opus" />
                <data android:mimeType="audio/amr" />
                <data android:mimeType="audio/midi" />
            </intent-filter>
        </activity>

        <!-- Midnight Violet — default launcher alias (enabled at install time) -->
        <activity-alias
            android:name=".MainActivityAliasMidnightViolet"
            android:targetActivity=".MainActivity"
            android:enabled="true"
            android:exported="true"
            android:label="@string/launcher_label"
            android:icon="@mipmap/wavdrop_icon_midnight_violet"
            android:roundIcon="@mipmap/wavdrop_icon_midnight_violet_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Clean Purple — disabled until the user switches to it -->
        <activity-alias
            android:name=".MainActivityAliasCleanPurple"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/launcher_label"
            android:icon="@mipmap/wavdrop_icon_clean_purple"
            android:roundIcon="@mipmap/wavdrop_icon_clean_purple_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Deep Teal — disabled until the user switches to it -->
        <activity-alias
            android:name=".MainActivityAliasDeepTeal"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/launcher_label"
            android:icon="@mipmap/wavdrop_icon_deep_teal"
            android:roundIcon="@mipmap/wavdrop_icon_deep_teal_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Obsidian Black - disabled until the user switches to it -->
        <activity-alias
            android:name=".MainActivityAliasObsidianBlack"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/launcher_label"
            android:icon="@mipmap/wavdrop_icon_obsidian_black"
            android:roundIcon="@mipmap/wavdrop_icon_obsidian_black_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Ocean Blue - disabled until the user switches to it -->
        <activity-alias
            android:name=".MainActivityAliasOceanBlue"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/launcher_label"
            android:icon="@mipmap/wavdrop_icon_ocean_blue"
            android:roundIcon="@mipmap/wavdrop_icon_ocean_blue_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Sunset Orange - disabled until the user switches to it -->
        <activity-alias
            android:name=".MainActivityAliasSunsetOrange"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/launcher_label"
            android:icon="@mipmap/wavdrop_icon_sunset_orange"
            android:roundIcon="@mipmap/wavdrop_icon_sunset_orange_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!--
            PlaybackService: MediaSessionService that owns ExoPlayer + MediaSession.
            exported=true is required so that media controllers (and the system
            media UI on Android 13+) can bind to the session.
            foregroundServiceType must match the FOREGROUND_SERVICE_MEDIA_PLAYBACK permission.
        -->
        <service
            android:name=".playback.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!--
            AudioOutputReconnectReceiver: wakes the app when a Bluetooth A2DP / HFP / hearing-aid
            profile connects, or when wired headphones are plugged in, so that playback can be
            resumed per the user's reconnect settings.
            exported="false": these are protected system broadcasts; no other app can send them.
        -->
        <receiver
            android:name=".playback.AudioOutputReconnectReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.HEADSET_PLUG" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.bluetooth.a2dp.profile.action.CONNECTION_STATE_CHANGED" />
                <action android:name="android.bluetooth.headset.profile.action.CONNECTION_STATE_CHANGED" />
                <action android:name="android.bluetooth.hearingaid.profile.action.CONNECTION_STATE_CHANGED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
