<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded layout: minH >= 300dp (~368dp target). Cinematic card: generous spacing,
     larger artwork, intentional use of vertical space. Content cluster centred. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_body"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wavdrop_widget_loading_background"
    android:clickable="true"
    android:focusable="true">

    <!-- Artwork atmosphere background -->
    <ImageView
        android:id="@+id/widget_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- Dark scrim over artwork -->
    <TextView
        android:id="@+id/widget_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC16131F"
        android:visibility="gone" />

    <!-- Content cluster — centred vertically, generous internal spacing -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="30dp"
        android:paddingBottom="30dp">

        <!-- Track info row: large artwork beside metadata -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/widget_artwork"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:scaleType="centerCrop"
                android:background="#FF2A2536"
                android:contentDescription="@string/widget_artwork_desc" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/widget_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#EDEAF4"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#A9A3B8"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Controls row — generous gap, slightly larger buttons than Tall -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp">

            <ImageButton
                android:id="@+id/widget_previous"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/widget_ic_skip_previous"
                android:background="@android:color/transparent"
                android:padding="6dp"
                android:contentDescription="@string/widget_prev_desc" />

            <ImageButton
                android:id="@+id/widget_play_pause"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="22dp"
                android:src="@drawable/widget_ic_play"
                android:background="@drawable/widget_btn_idle_bg"
                android:padding="10dp"
                android:contentDescription="@string/widget_play_pause_desc" />

            <ImageButton
                android:id="@+id/widget_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="22dp"
                android:src="@drawable/widget_ic_skip_next"
                android:background="@android:color/transparent"
                android:padding="6dp"
                android:contentDescription="@string/widget_next_desc" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
