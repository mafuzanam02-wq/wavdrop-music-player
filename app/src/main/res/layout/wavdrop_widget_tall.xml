<?xml version="1.0" encoding="utf-8"?>
<!-- Full Player layout (wavdrop_widget_tall.xml): 4×2 default placement, minH 115–299dp.
     Vertically centred content block. 48dp minimum touch targets on all controls. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_body"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wavdrop_widget_loading_background"
    android:clickable="true"
    android:focusable="true">

    <!-- Artwork atmosphere background -->
    <ImageView
        android:id="@+id/widget_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- Dark scrim over artwork -->
    <TextView
        android:id="@+id/widget_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC16131F"
        android:visibility="gone" />

    <!-- Content block — vertically centred -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Track info row: artwork beside title/artist -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/widget_artwork"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:scaleType="centerCrop"
                android:background="#FF2A2536"
                android:contentDescription="@string/widget_artwork_desc" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/widget_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#EDEAF4"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="#A9A3B8"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Controls row — 48dp minimum touch target on all buttons.
             Padding keeps the icon glyph visually restrained. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <!-- Previous: 48×48dp container, ~24dp effective glyph area -->
            <ImageButton
                android:id="@+id/widget_previous"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/widget_ic_skip_previous"
                android:background="@android:color/transparent"
                android:padding="12dp"
                android:contentDescription="@string/widget_prev_desc" />

            <!-- Play/Pause: 56×56dp container, ~28dp effective glyph area -->
            <ImageButton
                android:id="@+id/widget_play_pause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/widget_ic_play"
                android:background="@drawable/widget_btn_idle_bg"
                android:padding="14dp"
                android:contentDescription="@string/widget_play_pause_desc" />

            <!-- Next: 48×48dp container, ~24dp effective glyph area -->
            <ImageButton
                android:id="@+id/widget_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/widget_ic_skip_next"
                android:background="@android:color/transparent"
                android:padding="12dp"
                android:contentDescription="@string/widget_next_desc" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
